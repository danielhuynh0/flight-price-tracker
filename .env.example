
# just to show that I am using an .env file, for demo

# AWS SQS queue
PRICE_EVENTS_QUEUE_URL=fake-url.com
NOTIFICATION_QUEUE_URL=fake-url.com

# AWS region
AWS_REGION=us-east-1

# DynamoDB table names
DYNAMO_MONITORING_TABLE=monitoring_requests
DYNAMO_PRICE_HISTORY_TABLE=price_history
DYNAMO_NOTIFICATION_TABLE=notification_history

# for polling Google Flights, in seconds
POLL_INTERVAL_SECONDS=300

# min hours between alerts for the same route per user
NOTIFICATION_COOLDOWN_HOURS=24

# Flask frontend
FLASK_SECRET_KEY=replace-with-a-long-random-string
FLASK_PORT=5000

# SMTP credentials (Component C - for email contacts)
# For Gmail, use an App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=you@gmail.com
